# ============================================================
# BASIL-MD — BOT CONFIGURATION
# ============================================================
# Copy this file to config.env and fill in your values.
#   cp config.env.example config.env
#
# Lines starting with # are comments and are ignored.
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────

# SESSION_ID — Get yours at https://basil-pair.onrender.com
# Format: BASIL-MD~<your-session-id>
SESSION_ID=""

# OWNER_NUMBER — Your WhatsApp number with country code, no +
# Example: 2638412345678
OWNER_NUMBER=""

# ── BOT IDENTITY ─────────────────────────────────────────────

# PREFIX — Command prefix (default: .)
PREFIX="."

# MODE — Who can use the bot: public | groups | private | inbox
MODE="public"

# BOT_MENUMODE — Menu style: reply | button
BOT_MENUMODE="reply"

# MULTI_PREFIX — Allow multiple prefixes (true/false)
MULTI_PREFIX="false"

# ALIVE_MSG — Message shown by .alive command
ALIVE_MSG="BASIL-MD IS ALIVE 🔥"

# ALIVE_IMG — Image URL shown with .alive (must be a direct image URL)
ALIVE_IMG="https://files.catbox.moe/alj4ot.jpg"

# ── SUDO / ADMINS ─────────────────────────────────────────────

# SUDOS — Up to 3 comma-separated numbers with bot admin access
SUDOS=""

# ── TIMEZONE ─────────────────────────────────────────────────

# TIME_ZONE — Optional. Bot auto-detects bot number timezone if blank.
# Examples: Africa/Harare | Africa/Lagos | Africa/Nairobi | America/New_York
TIME_ZONE=""

# ── DATABASE ─────────────────────────────────────────────────

# DATABASE_URL — PostgreSQL connection string (optional)
# Free options: Neon.tech (https://neon.tech) or Supabase (https://supabase.com)
# If blank, the bot uses local SQLite (data WON'T persist after a restart/redeploy)
DATABASE_URL=""

# POSTGRE_URI — Alias for DATABASE_URL (use either one)
POSTGRE_URI=""

# ── AI / CHATBOT ──────────────────────────────────────────────

# CHATBOT_MODE — Enable AI chatbot replies (true/false)
CHATBOT_MODE="false"

# AI_ENDPOINT — Custom OpenAI-compatible API base URL
AI_ENDPOINT=""

# AI_API_KEY — API key for the AI provider
AI_API_KEY=""

# AI_MODEL — Model name (default: gpt-3.5-turbo or provider default)
AI_MODEL="default"

# ── AUTO FEATURES ─────────────────────────────────────────────

# AUTO_READ_STATUS — Auto-view WhatsApp statuses (true/false)
AUTO_READ_STATUS="false"

# AUTO_READ_MSG — Auto-read all messages (true/false)
AUTO_READ_MSG="false"

# AUTO_STATUS_LIKE — Auto-like statuses (on/off)
AUTO_STATUS_LIKE="off"

# AUTO_STATUS_REPLY — Auto-reply to statuses (true/false)
AUTO_STATUS_REPLY="false"

# AUTO_REACT — Auto-react to messages (true/false)
AUTO_REACT="false"

# CUSTOM_REACT — Use custom emoji for auto-react (true/false)
CUSTOM_REACT="false"

# OWNER_REACT — React to owner messages (true/false)
OWNER_REACT="true"

# AUTO_REPLY — Auto-reply to unknown messages (true/false)
AUTO_REPLY="false"

# AUTO_STICKER — Auto-convert images to stickers (true/false)
AUTO_STICKER="false"

# AUTO_VOICE — Auto-convert text to voice (true/false)
AUTO_VOICE="false"

# BOT_PRESENCE — Show bot as online/typing (true/false)
BOT_PRESENCE="false"

# ── GROUP MANAGEMENT ─────────────────────────────────────────

# WELCOME — Send welcome message when members join (true/false)
WELCOME="true"

# GOODBYE — Send goodbye message when members leave (true/false)
GOODBYE="true"

# ANTI_LINK — Delete links posted by non-admins (true/false)
ANTI_LINK="false"

# ANTI_LINK_ACT — Action on link violation: warn | kick | delete
ANTI_LINK_ACT="false"

# ANTI_DELETE — Recover deleted messages (true/false)
ANTI_DELETE="false"

# ANTI_EDIT — Log edited messages (true/false)
ANTI_EDIT="false"

# ANTI_VV — Recover view-once messages (true/false)
ANTI_VV="false"

# ANTI_DEMOTE — Kick anyone who demotes the bot (true/false)
ANTI_DEMOTE="false"

# ANTI_CALL — Reject incoming calls (true/false)
ANTI_CALL="false"

# ANTI_BOT — Kick other bots from groups (true/false)
ANTI_BOT="false"

# ANTI_TAG — Prevent mass tagging (true/false)
ANTI_TAG="false"
