{
  "name": "BASIL-MD",
  "version": "2.1.0",
  "description": "A WhatsApp bot created by STRIKERBOY and Tife",
  "type": "module",
  "main": "start.js",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "start": "pm2 start start.js --deep-monitoring --attach --name BASIL-MD",
    "start:node": "node start.js",
    "stop": "pm2 stop BASIL-MD",
    "restart": "pm2 restart BASIL-MD",
    "install:lite": "npm install --no-optional --no-audit --no-fund --legacy-peer-deps",
    "install:full": "npm install",
    "lint": "eslint \"index.js\" \"config.js\" \"core/**/*.js\" \"lib/**/*.js\" \"plugins/**/*.js\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "check:syntax": "node --input-type=module -e \"import('./index.js').catch(()=>{});\" || true",
    "verify": "node --check index.js && node --check config.js && node --check core/connect.js",
    "bundle:pack": "node scripts/pack.mjs",
    "bundle:release": "node scripts/pack.mjs --release-only",
    "secrets:encrypt": "node scripts/encrypt-secrets.mjs",
    "secrets:decrypt": "node scripts/decrypt-secrets.mjs",
    "test:compat": "node scripts/smoke-compat.mjs",
    "test:chess": "node scripts/smoke-chess.mjs",
    "test": "npm run test:compat && npm run test:chess"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@mrnima/facebook-downloader": "^1.0.0",
    "@tobyg74/tiktok-api-dl": "^1.0.0",
    "acorn": "^8.8.2",
    "acrcloud": "^1.4.0",
    "adm-zip": "^0.5.16",
    "aki-api": "^7.0.1",
    "axios": "^1.7.7",
    "better-sqlite3": "11.10.0",
    "btch-downloader": "^1.0.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "chess.js": "^1.0.0",
    "countries-and-timezones": "^3.8.0",
    "country-data": "0.0.31",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.39.1",
    "express": "^4.18.2",
    "fg-senna": "^0.0.7",
    "file_size_url": "^1.0.4",
    "file-type": "^20.5.0",
    "form-data": "^4.0.2",
    "fs-extra": "^11.1.0",
    "g4f": "^1.0.0",
    "gifencoder": "^2.0.1",
    "gifted-baileys": "^2.5.8",
    "gifted-btns": "^1.0.2",
    "googlethis": "^1.8.0",
    "human-readable": "^0.2.1",
    "jimp": "^0.16.2",
    "js-beautify": "^1.15.4",
    "link-preview-js": "^3.0.14",
    "luxon": "^3.6.1",
    "md5": "^2.3.0",
    "megajs": "^1.3.6",
    "moment-timezone": "^0.5.47",
    "nayan-media-downloaders": "^0.1.8",
    "nima-google-now": "^1.0.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.6.1",
    "node-os-utils": "^2.0.1",
    "pdf-lib": "^1.17.1",
    "performance-now": "^2.1.0",
    "pg": "8.20.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.4",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7",
    "translate-google-api": "^1.0.4",
    "twitter-downloader": "^1.0.0",
    "uuid": "^9.0.0",
    "webcrack": "^2.15.1",
    "ws": "^8.17.0",
    "pdf-parse": "^1.1.1",
    "yt-search": "^2.12.1"
  },
  "optionalDependencies": {
    "canvas": "^3.1.2",
    "ffcreator": "^2.17.3",
    "fluent-ffmpeg": "^2.1.3",
    "pdfkit": "^0.14.0",
    "sharp": "^0.32.6"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "eslint-plugin-import": "^2.29.1",
    "javascript-obfuscator": "^4.1.1",
    "pm2": "^5.4.2",
    "prettier": "^3.3.3"
  }
}
